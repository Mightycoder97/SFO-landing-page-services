---
import Layout from '../layouts/Layout.astro';
import FloatingContact from '../components/FloatingContact.astro';

const phoneNumber = "51907526005";
const displayPhone = "+51 907 526 005";
const whatsappMessage = "Hola! Vengo de la página web y necesito un servicio de gasfitería.";
---

<Layout 
  title="Gasfitero Juliaca - Servicio Inmediato 24/7"
  description="Gasfitero en Juliaca con atención inmediata para emergencias. Servicio profesional garantizado. Contáctanos ahora por WhatsApp o teléfono."
  hideHeader
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content animate-fade-in">
      <span class="badge">Servicio 24/7 en Juliaca y Todo el Perú</span>
      <h1>
        <span class="text-white">Gasfitería en </span>
        <span class="text-gradient">Juliaca</span>
        <span class="text-white"> Servicio Inmediato</span>
      </h1>
      <p class="hero-desc">Los mejores gasfiteros en Juliaca para atender tus emergencias las 24 horas. Llama ahora al <strong>{displayPhone}</strong> para el mejor servicio técnico de Juliaca.</p>
      
      <!-- Contact Buttons -->
      <div class="contact-actions">
        <a 
          href={`https://wa.me/${phoneNumber}?text=${encodeURIComponent(whatsappMessage)}`} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="btn btn-whatsapp btn-lg contact-wa"
        >
          Escribir al WhatsApp
        </a>
        <a 
          href={`tel:+${phoneNumber}`} 
          class="btn btn-secondary btn-lg contact-phone"
        >
          Teléfono: {displayPhone}
        </a>
        <p class="contact-phone-sub">Atención en todo Juliaca: {displayPhone}</p>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-subtle">
    <div class="container">
      <h2 class="title-lg text-center">¿Por qué contactarnos?</h2>
      <p class="text-light max-w-2xl mx-auto">Nuestro servicio está diseñado para resolver tus problemas de gasfitería de forma rápida y profesional.</p>
      
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">
            <i class="ph ph-clock-counter-clockwise text-primary"></i>
          </div>
          <h3>Respuesta Inmediata en Juliaca</h3>
          <p class="text-light">Atención inmediata las 24 horas para emergencias de gasfitería en Juliaca y alrededores. Llegamos rápido a cualquier punto de Juliaca llamando al {displayPhone}.</p>
        </div>
        
        <div class="benefit-card">
          <div class="benefit-icon">
            <i class="ph ph-shield-check text-primary"></i>
          </div>
          <h3>Trabajo Profesional Garantizado</h3>
          <p class="text-light">Técnicos certificados en Juliaca que garantizan un trabajo profesional y duradero en cada servicio.</p>
        </div>
        
        <div class="benefit-card">
          <div class="benefit-icon">
            <i class="ph ph-map-pin-line text-primary"></i>
          </div>
          <h3>Gasfitería 24/7 en Juliaca</h3>
          <p class="text-light">Especialistas locales en Juliaca con atención personalizada. Atendemos en toda la ciudad de Juliaca y Puno. WhatsApp: {displayPhone}.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Highlighted Service: Trampa de Grasas -->
  <section class="section bg-white overflow-hidden">
    <div class="container">
      <div class="highlight-service-container">
        <div class="highlight-image">
          <img src="/img/trampa_grasa.jpeg" alt="Instalación de trampas de grasa en Juliaca" class="rounded-lg shadow-lg" />
        </div>
        <div class="highlight-content">
          <span class="badge">Nuevo Servicio Especializado</span>
          <h2 class="title-lg">Trampas de Grasa en Juliaca</h2>
          <p class="text-light mb-6">Fabricación e instalación de trampas de grasas para viviendas y comercios en Juliaca. Cumple con las normativas locales y garantiza el correcto funcionamiento de tus desagües en Juliaca.</p>
          <div class="flex gap-4">
            <a href={`tel:+${phoneNumber}`} class="btn btn-secondary">
              Llamar al {displayPhone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid Section -->
  <section class="section">
    <div class="container">
      <h2 class="title-lg text-center">Nuestros Servicios de Gasfitería en Juliaca</h2>
      <p class="text-light max-w-2xl mx-auto">Soluciones rápidas y efectivas para cualquier problema técnico en Juliaca. Llámanos al {displayPhone} para asistencia en Juliaca.</p>
      
      <div class="services-compact-grid">
        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-drop-half-bottom"></i>
          </div>
          <h4>Instalación de agua y desagüe</h4>
          <p class="text-light">Redes de agua potable y sistemas de evacuación.</p>
        </div>
        
        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-shower"></i>
          </div>
          <h4>Ducha y terma eléctrica</h4>
          <p class="text-light">Instalación y mantenimiento de duchas y termas.</p>
        </div>
        
        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-waves"></i>
          </div>
          <h4>Tanque y cisterna</h4>
          <p class="text-light">Instalación garantizada de sistemas de almacenamiento.</p>
        </div>
        
        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-engine"></i>
          </div>
          <h4>Electrobomba</h4>
          <p class="text-light">Sistemas de bombeo y presión constante.</p>
        </div>
        
        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-thermometer-hot"></i>
          </div>
          <h4>Agua fría y caliente</h4>
          <p class="text-light">Instalaciones hidráulicas para agua fría y caliente.</p>
        </div>
        
        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-gear-six"></i>
          </div>
          <h4>Instalación de fluxómetros</h4>
          <p class="text-light">Especialistas en grifería de alta presión.</p>
        </div>
        
        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-fire"></i>
          </div>
          <h4>Sistemas de termofusión</h4>
          <p class="text-light">Expertos en soldadura por termofusión para PPR.</p>
        </div>
        
        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-grid-four"></i>
          </div>
          <h4>Porcelanato y cerámica</h4>
          <p class="text-light">Enchapados profesionales en baños y cocinas.</p>
        </div>

        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-file-text"></i>
          </div>
          <h4>Planos y certificaciones</h4>
          <p class="text-light">Elaboración de planos y certificados de operatividad.</p>
        </div>

        <div class="service-item">
          <div class="service-icon">
            <i class="ph ph-trend-down"></i>
          </div>
          <h4>Excesos de consumo</h4>
          <p class="text-light">Detección de fugas para reducir cobros excesivos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-primary">
    <div class="container">
      <div class="text-center">
        <h2 class="title-lg text-white mb-8">¿Necesitas un gasfiter en Juliaca ahora?</h2>
        <p class="text-light max-w-2xl mx-auto mb-8">Atención inmediata en Juliaca y alrededores. Contacta al <strong>{displayPhone}</strong> para el mejor gasfitero de Juliaca.</p>
        
        <div class="final-contact-actions flex flex-col sm:flex-row gap-6">
          <a 
            href={`https://wa.me/${phoneNumber}?text=${encodeURIComponent(whatsappMessage)}`} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="btn btn-whatsapp btn-lg w-full sm:w-1/2"
          >
            Escribir al WhatsApp
          </a>
          <a 
            href={`tel:+${phoneNumber}`} 
            class="btn btn-secondary btn-lg w-full sm:w-1/2"
          >
            Teléfono: {displayPhone}
          </a>
        </div>
        <p class="text-white mt-6 font-bold">Llámanos ahora en Juliaca al {displayPhone} - Gasfiteros Juliaca 24h</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    padding: 10rem 0;
    overflow: hidden;
    color: white;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }
  
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.8)), url('https://images.unsplash.com/photo-1585704032915-c3400ca199e7?q=80&w=2070&auto=format&fit=crop') center/cover;
    z-index: -1;
  }
  
  .hero-logo {
    position: absolute;
    top: 1rem;
    left: 1rem;
    width: 35px;
    height: 35px;
    opacity: 0.8;
    pointer-events: none;
  }
  
  .hero-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  
  .hero-content {
    max-width: 800px;
    text-align: center;
    padding: 0 1rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .text-gradient {
    background: linear-gradient(to right, #25D366, #128C7E);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
  
  .text-white {
    color: white;
  }
  
  .btn-whatsapp {
    background-color: #25D366;
    color: white;
    border: none;
  }
  
  .btn-whatsapp:hover {
    background-color: #1eb959;
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 12px 20px -8px rgba(37, 211, 102, 0.4);
  }

  /* Enhancing global btn transitions for the striking hover effect */
  .btn {
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .btn-secondary {
    background-color: var(--color-secondary);
    color: white;
    border: none;
  }

  .btn-secondary:hover {
    background-color: var(--color-secondary-hover);
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 12px 20px -8px rgba(245, 188, 24, 0.4);
  }
  
  /* Removed unused outline styles as requested for solid high-contrast buttons */
  
  .whatsapp-icon {
    font-size: 1.5rem;
  }
  
  .hero-content {
    max-width: 800px;
    text-align: center;
  }
  
  .badge {
    display: inline-block;
    background-color: rgba(245, 188, 24, 0.2);
    color: var(--color-secondary);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(245, 188, 24, 0.4);
  }
  
  h1 {
    font-size: clamp(3rem, 6vw, 4.5rem);
    color: white;
    margin-bottom: 1.5rem;
  }
  
  .text-highlight {
    color: var(--color-primary);
  }
  
  .hero-desc {
    font-size: 1.25rem;
    opacity: 0.9;
    max-width: 650px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }
  
  .contact-actions {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    margin-top: 2rem;
  }
  
  .contact-wa,
  .contact-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
  
  .display-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  
  .contact-phone-sub {
    font-size: 1.1rem;
    color: white;
    opacity: 0.9;
    margin-top: 1rem;
    font-weight: 600;
  }
  
  .btn-lg {
    padding: 1rem 1.5rem;
    font-size: clamp(0.9rem, 2.5vw, 1.125rem);
    font-weight: 700;
    width: auto;
    max-width: fit-content;
    white-space: nowrap;
  }
  
  .border-white {
    border-color: rgba(255, 255, 255, 0.5);
  }
  
  .border-white:hover {
    background-color: white;
    color: var(--color-text-dark);
  }
  
  /* Benefits Section */
  .benefits-grid {
    display: grid;
    gap: 2rem;
    margin-top: 3rem;
  }
  
  .benefit-card {
    background-color: white;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .benefit-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }
  
  .benefit-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1.5rem;
    background-color: rgba(63, 87, 181, 0.1);
    color: var(--color-secondary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
  }
  
  .benefit-card h3 {
    font-size: 1.25rem;
    margin: 1rem 0;
    color: var(--color-text-dark);
  }
  
  .benefit-card p {
    color: var(--color-text-light);
    line-height: 1.6;
  }
  
  /* Services Compact Grid */
  .services-compact-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  
  .service-item {
    background-color: white;
    padding: 1.5rem;
    border-radius: var(--radius-md);
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid var(--color-border);
  }
  
  .service-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-secondary);
  }
  
  .service-icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1rem;
    background-color: rgba(63, 87, 181, 0.1);
    color: var(--color-secondary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }
  
  .service-item h4 {
    font-size: 1.1rem;
    margin: 0.5rem 0;
    color: var(--color-text-dark);
  }
  
  .service-item p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.4;
    margin: 0;
  }
  
  /* Final CTA Section */
  .section.bg-primary {
    background: var(--color-primary);
    background: linear-gradient(to right, var(--color-primary), #1a365d);
    text-align: center;
    min-height: 20vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .section.bg-primary h2 {
    color: white;
    margin-bottom: 1.5rem;
  }
  
  .section.bg-primary p {
    color: rgba(255, 255, 255, 0.9);
    max-width: 500px;
    margin: 0 auto 2rem;
  }
  
  .whatsapp-icon {
    font-size: 1.5rem;
  }
  
  .service-item {
    background-color: white;
    padding: 1.5rem;
    border-radius: var(--radius-md);
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid var(--color-border);
  }
  
  .service-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-secondary);
  }
  
  .service-icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1rem;
    background-color: rgba(63, 87, 181, 0.1);
    color: var(--color-secondary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }
  
  .service-item h4 {
    font-size: 1.1rem;
    margin: 0.5rem 0;
    color: var(--color-text-dark);
  }
  
  .service-item p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.4;
    margin: 0;
  }
  
  /* Final CTA Section */
  .final-contact-actions {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2.5rem;
    align-items: center;
  }
  
  .final-contact-actions .btn-lg {
    padding: 1.25rem 2rem;
    font-size: clamp(1rem, 3vw, 1.25rem);
    font-weight: 700;
    white-space: nowrap;
    width: auto;
  }
  
  /* Responsive adjustments */
  @media (min-width: 768px) {
    .benefits-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    
    .services-compact-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    
    .final-contact-actions {
      flex-direction: row;
      gap: 1.5rem;
      justify-content: center;
    }
    
    .final-contact-actions .btn-lg {
      /* Remove flex: 1 to prevent stretching, let buttons size to content */
    }
    
    .hero-content {
      text-align: left;
    }
    
    .contact-actions {
      align-items: stretch;
    }
  }
  
  @media (max-width: 767px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
    
    .services-compact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .final-contact-actions {
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
      width: 100%;
    }
    
    .services-compact-grid {
      grid-template-columns: 1fr;
    }
    
    .hero {
      padding: 6rem 0;
      min-height: 80vh;
    }
    
    .hero-logo {
      top: 0.5rem;
      left: 0.5rem;
      width: 30px;
      height: 30px;
    }

    .highlight-service-container {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }

    .highlight-image img {
      max-width: 100%;
    }
  }

  /* Highlight Section Styles */
  .highlight-service-container {
    display: flex;
    align-items: center;
    gap: 4rem;
    margin: 2rem 0;
    padding: 2rem;
    background: #f8fafc;
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-secondary);
  }

  .highlight-image {
    flex: 1;
  }

  .highlight-image img {
    width: 100%;
    max-width: 500px;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .highlight-content {
    flex: 1;
  }
</style>