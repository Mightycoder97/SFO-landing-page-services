---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingContact from '../components/FloatingContact.astro';

// Import local fonts
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';

interface Props {
 	title: string;
 	description?: string;
 	image?: string;
 	canonicalURL?: string | URL;
 	type?: 'website' | 'article';
 	hideHeader?: boolean;
 }

 const { 
 	title, 
 	description = "Gasfitero en Juliaca. Servicios a nivel nacional, atención rápida y profesional para hogares y empresas. Detección de fugas, desatoros, termas y más.", 
 	image = "/img/logo-3.png", 
 	canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://www.gasfiteroenjuliaca.pe'),
 	type = 'website',
 	hideHeader = false
 } = Astro.props;

const structuredData = {
	"@context": "https://schema.org",
	"@type": "PlumbingService",
	"name": "Gasfitero en Juliaca",
	"description": description,
	"image": new URL(image, canonicalURL).toString(),
	"url": canonicalURL.toString(),
	"telephone": "+51907526005",
	"email": "emergencias@gasfiteroenjuliaca.pe",
	"priceRange": "$$",
	"address": {
		"@type": "PostalAddress",
		"streetAddress": "Juliaca Central",
		"addressLocality": "Juliaca",
		"addressRegion": "Puno",
		"postalCode": "21101",
		"addressCountry": "PE"
	},
	"geo": {
		"@type": "GeoCoordinates",
		"latitude": -15.4957,
		"longitude": -70.1332
	},
	"areaServed": [
		{
			"@type": "City",
			"name": "Juliaca",
			"sameAs": "https://en.wikipedia.org/wiki/Juliaca"
		},
		{
			"@type": "City",
			"name": "Puno"
		}
	],
	"openingHoursSpecification": {
		"@type": "OpeningHoursSpecification",
		"dayOfWeek": [
			"Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"
		],
		"opens": "00:00",
		"closes": "23:59"
	},
	"hasOfferCatalog": {
		"@type": "OfferCatalog",
		"name": "Servicios de Gasfitería",
		"itemListElement": [
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "Detección de fugas de agua"
				}
			},
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "Desatoro de desagües"
				}
			},
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "Instalación de termas"
				}
			}
		]
	}
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL} />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Base -->
		<title>{title} | Gasfitero en Juliaca</title>
		<meta name="robots" content="index, follow" />
		<meta name="googlebot" content="index, follow" />
		<meta name="theme-color" content="#1B8DF5" />
		<meta name="keywords" content="gasfitero Juliaca, plomero Juliaca, gasfiteria Puno, desatoros Juliaca, fugas de agua Juliaca, instalacion de termas, servicio tecnico gasfiteria, gasfitero 24 horas" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | Gasfitero en Juliaca`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, canonicalURL).toString()} />
		<meta property="og:locale" content="es_PE" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} | Gasfitero en Juliaca`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, canonicalURL).toString()} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>

		<!-- Phosphor Icons -->
		<script is:inline src="https://unpkg.com/@phosphor-icons/web"></script>
		<slot name="head" />

		<!-- Script para deshabilitar inspección de código -->
		<script is:inline>
			// Deshabilitar clic derecho
			document.addEventListener('contextmenu', (e) => e.preventDefault());

			// Deshabilitar atajos de teclado comunes
			document.onkeydown = function(e) {
				// F12
				if (e.keyCode == 123) {
					return false;
				}
				// Ctrl+Shift+I, Ctrl+Shift+J, Ctrl+Shift+C (Inspeccionar)
				if (e.ctrlKey && e.shiftKey && (e.keyCode == 73 || e.keyCode == 74 || e.keyCode == 67)) {
					return false;
				}
				// Ctrl+U (Ver código fuente)
				if (e.ctrlKey && e.keyCode == 85) {
					return false;
				}
				// Ctrl+S (Guardar página)
				if (e.ctrlKey && e.keyCode == 83) {
					return false;
				}
				// Atajos para Mac (Cmd + Opt + I/J o Cmd + U)
				if (e.metaKey && e.altKey && (e.keyCode == 73 || e.keyCode == 74)) {
					return false;
				}
				if (e.metaKey && e.keyCode == 85) {
					return false;
				}
				if (e.metaKey && e.keyCode == 83) {
					return false;
				}
			};

			// Opcional: Limpiar consola constantemente
			setInterval(() => {
				console.clear();
			}, 1000);
		</script>
	</head>
	<body>
  {hideHeader ? null : <Header />}
  <main>
    <slot />
  </main>
  <Footer />
  <FloatingContact />
	</body>
</html>
